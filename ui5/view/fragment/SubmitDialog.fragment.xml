<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="submitDialog"
        title="{i18n>confirmTitle}"
        type="Message"
        contentWidth="24rem">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text
                    id="submitDialogMessage"
                    text="{= ${detail>/CreditMemo} === 'X' ? ${i18n>msgSubmitConfirmCreditMemo} : ${i18n>msgSubmitConfirmInvoice} }" />
            </VBox>
        </content>
        <beginButton>
            <Button
                text="{i18n>okButton}"
                type="Emphasized"
                press=".onSubmitConfirm" />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>cancelButton}"
                press=".onSubmitCancel" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>
