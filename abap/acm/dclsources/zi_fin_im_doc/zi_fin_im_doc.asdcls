@EndUserText.label: 'Access Control for VIM Document'
@MappingRole: true
define role ZI_FIN_IM_DOC {
  grant select on ZI_FIN_IM_DOC
    where 
      // Users can only see documents for company codes they're authorised for
      // Using standard FI authorisation object F_BKPF_BUK
      (CompanyCode) = aspect pfcg_auth(F_BKPF_BUK, BUKRS, ACTVT='03');
      // ACTVT='03' = Display/Read
}